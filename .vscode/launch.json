{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Open Chrome (fresh start)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src",
      "preLaunchTask": "dev: kill port and start",
      "presentation": { "order": 1 },
      "comment": "Kills any existing server on :3001, then starts fresh. Use this if Claude Desktop or another process has the port."
    },
    {
      "name": "Open Chrome (attach to running)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src",
      "presentation": { "order": 2 },
      "comment": "Just opens the browser — assumes server is already running. Use when npm run dev is already up."
    },
    {
      "name": "Open Edge (fresh start)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client/src",
      "preLaunchTask": "dev: kill port and start",
      "presentation": { "order": 3 }
    },
    {
      "name": "Debug Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/server/node_modules/.bin/tsx",
      "args": ["watch", "src/server.ts"],
      "cwd": "${workspaceFolder}/server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/server/dist/**/*.js"],
      "env": { "NODE_ENV": "development" },
      "console": "integratedTerminal",
      "presentation": { "order": 4 },
      "comment": "Runs server alone in Node debugger. Set breakpoints in server/src/*.ts."
    }
  ]
}
