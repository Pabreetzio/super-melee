{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kill: dev ports",
      "type": "shell",
      "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .vscode\\nuke-dev.ps1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "nuke: dev stack",
      "type": "shell",
      "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .vscode\\nuke-dev.ps1",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "dev: start inspect stack",
      "type": "shell",
      "command": "node scripts/dev-stack.mjs",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "dependsOn": ["kill: dev ports"],
      "problemMatcher": {
        "owner": "vite",
        "pattern": [{ "regexp": "^$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[0\\]",
          "endsPattern": "Local:.*43187"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev",
        "clear": true
      }
    },
    {
      "label": "client: generate atlases",
      "type": "shell",
      "command": "node ./scripts/generate-atlases.mjs",
      "options": { "cwd": "${workspaceFolder}/client" },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
