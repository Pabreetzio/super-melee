{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "kill: port 3001",
      "type": "shell",
      "command": "npx --yes kill-port 3001 & exit 0",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "dev: start all",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "dependsOn": [],
      "problemMatcher": {
        "owner": "vite",
        "pattern": [{ "regexp": "^$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[0\\]",
          "endsPattern": "Local:.*5173"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev",
        "clear": true
      }
    },
    {
      "label": "dev: kill port and start",
      "dependsOrder": "sequence",
      "dependsOn": ["kill: port 3001", "dev: start all"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "dev: server only",
      "type": "shell",
      "command": "npm run dev --prefix server",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "server",
        "pattern": [{ "regexp": "^$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "listening on"
        }
      }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always" }
    }
  ]
}
